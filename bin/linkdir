#!/usr/bin/env bash
set -euo pipefail

PROGRAM="linkdir"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/linkdir"
DB_FILE="$CONFIG_DIR/links.db"
SQLITE_HEADER="SQLite format 3"

COLOR_ENABLED=0
if [[ -t 1 ]]; then
  COLOR_ENABLED=1
fi

color() {
  local code="$1"
  shift
  if [[ "$COLOR_ENABLED" -eq 1 ]]; then
    printf '\033[%sm%s\033[0m\n' "$code" "$*"
  else
    printf '%s\n' "$*"
  fi
}

info() {
  color "1" "$*"
}

success() {
  color "32" "$*"
}

error() {
  color "31" "$*" >&2
}

usage() {
  cat <<'EOF'
Usage:
  linkdir add <key> <value>      Add or overwrite a mapping
  linkdir open <key>             Open mapping: URL, directory, or shell command
  linkdir path <key>             Print directory/value for shell integration
  linkdir list                   List all mappings
  linkdir remove <key>           Remove a mapping
  linkdir f                      Fuzzy-find a key using fzf and open it
  linkdir help                   Show this help

Examples:
  linkdir add gh https://github.com
  linkdir add proj ~/workspace/project
  linkdir open gh
  linkdir open proj
  linkdir remove gh

Directory navigation note:
  A standalone executable cannot change your current shell directory.
  To jump directories from mappings, add this to your shell rc:

    lgo() { cd "$(linkdir path "$1")"; }

Then run:
  lgo proj
EOF
}

ensure_store() {
  mkdir -p "$CONFIG_DIR"
}

require_sqlite() {
  if ! command -v sqlite3 >/dev/null 2>&1; then
    error "sqlite3 is required but not found in PATH."
    return 1
  fi
}

sql_escape() {
  local raw="$1"
  printf '%s' "$raw" | sed "s/'/''/g"
}

is_sqlite_file() {
  [[ -s "$DB_FILE" ]] || return 1
  local header
  # SQLite databases start with this fixed 15-byte magic header.
  header="$(head -c 15 "$DB_FILE" 2>/dev/null || true)"
  [[ "$header" == "$SQLITE_HEADER" ]]
}

init_schema() {
  if ! sqlite3 "$DB_FILE" <<'SQL'
CREATE TABLE IF NOT EXISTS mappings (
  key TEXT PRIMARY KEY,
  value TEXT NOT NULL,
  created_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP,
  updated_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP
);
SQL
  then
    error "Failed to initialize SQLite schema at: $DB_FILE"
    return 1
  fi
}

migrate_legacy_db() {
  [[ -s "$DB_FILE" ]] || return 0
  if is_sqlite_file; then
    return 0
  fi

  # Migrate into a temporary SQLite DB first, then swap files only on success.
  local tmp backup line line_no key value skey svalue
  tmp="$(mktemp "$CONFIG_DIR/.links.db.sqlite.tmp.XXXXXX")"
  backup="$DB_FILE.legacy.$(date +%Y%m%d%H%M%S).bak"

  if ! sqlite3 "$tmp" <<'SQL'
CREATE TABLE IF NOT EXISTS mappings (
  key TEXT PRIMARY KEY,
  value TEXT NOT NULL,
  created_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP,
  updated_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP
);
SQL
  then
    rm -f "$tmp"
    error "Failed to prepare temporary SQLite database for migration."
    return 1
  fi

  line_no=0
  while IFS= read -r line || [[ -n "$line" ]]; do
    ((line_no += 1))
    [[ -z "$line" ]] && continue

    if [[ "$line" != *"|"* ]]; then
      rm -f "$tmp"
      error "Legacy DB migration failed: missing delimiter on line $line_no."
      return 1
    fi

    key="${line%%|*}"
    value="${line#*|}"
    if [[ -z "$key" ]]; then
      rm -f "$tmp"
      error "Legacy DB migration failed: empty key on line $line_no."
      return 1
    fi
    if ! validate_key "$key"; then
      rm -f "$tmp"
      error "Legacy DB migration failed: invalid key on line $line_no."
      return 1
    fi

    skey="$(sql_escape "$key")"
    svalue="$(sql_escape "$value")"
    if ! sqlite3 "$tmp" "INSERT INTO mappings (key, value) VALUES ('$skey', '$svalue') ON CONFLICT(key) DO UPDATE SET value=excluded.value, updated_at=CURRENT_TIMESTAMP;"; then
      rm -f "$tmp"
      error "Legacy DB migration failed while inserting line $line_no."
      return 1
    fi
  done <"$DB_FILE"

  if ! mv "$DB_FILE" "$backup"; then
    rm -f "$tmp"
    error "Migration failed: could not create backup at $backup"
    return 1
  fi

  if ! mv "$tmp" "$DB_FILE"; then
    error "Migration failed: could not place SQLite DB at $DB_FILE"
    error "Backup is preserved at: $backup"
    return 1
  fi

  success "Migrated legacy mappings to SQLite. Backup: $backup"
}

ensure_db_ready() {
  # Central preflight for every command that touches persistence.
  ensure_store
  require_sqlite
  migrate_legacy_db
  init_schema
}

validate_key() {
  local key="$1"
  if [[ -z "$key" ]]; then
    error "Key cannot be empty."
    return 1
  fi
  if [[ ! "$key" =~ ^[A-Za-z0-9._-]+$ ]]; then
    error "Invalid key '$key'. Use letters, numbers, dot, underscore, or hyphen."
    return 1
  fi
}

read_value() {
  local key="$1"
  local skey row sep
  skey="$(sql_escape "$key")"
  # Prefix the row with a sentinel column so empty-string values are distinguishable from "no row".
  sep=$'\x1f'
  if ! row="$(sqlite3 -noheader -separator "$sep" "$DB_FILE" "SELECT 1, value FROM mappings WHERE key='$skey' LIMIT 1;")"; then
    error "Failed to read mapping for key: $key"
    return 2
  fi
  if [[ -z "$row" ]]; then
    return 1
  fi
  printf '%s\n' "${row#*"$sep"}"
}

add_mapping() {
  local key="${1:-}"
  local value="${2:-}"

  validate_key "$key"
  if [[ -z "$value" ]]; then
    error "Value cannot be empty."
    return 1
  fi

  ensure_db_ready

  local skey svalue
  skey="$(sql_escape "$key")"
  svalue="$(sql_escape "$value")"

  if ! sqlite3 "$DB_FILE" "INSERT INTO mappings (key, value) VALUES ('$skey', '$svalue') ON CONFLICT(key) DO UPDATE SET value=excluded.value, updated_at=CURRENT_TIMESTAMP;"; then
    error "Failed to save mapping for key: $key"
    return 1
  fi
  success "Saved mapping: $key"
}

list_mappings() {
  ensure_db_ready

  local rows
  if ! rows="$(sqlite3 -noheader -separator '|' "$DB_FILE" "SELECT key, value FROM mappings ORDER BY key;")"; then
    error "Failed to list mappings."
    return 1
  fi

  if [[ -z "$rows" ]]; then
    info "No mappings stored yet."
    return 0
  fi

  if command -v column >/dev/null 2>&1; then
    {
      printf 'KEY|VALUE\n'
      printf '%s\n' "$rows"
    } | column -t -s '|'
  else
    printf '%-20s %s\n' "KEY" "VALUE"
    printf '%s\n' "$rows" | awk -F'|' '{ if (NF>=2) { sub(/^[^|]*\|/, "", $0); printf "%-20s %s\n", $1, $0 } }'
  fi
}

remove_mapping() {
  local key="${1:-}"
  validate_key "$key"
  ensure_db_ready

  local skey changes
  skey="$(sql_escape "$key")"
  if ! changes="$(sqlite3 -noheader "$DB_FILE" "DELETE FROM mappings WHERE key='$skey'; SELECT changes();")"; then
    error "Failed to remove mapping: $key"
    return 1
  fi
  if [[ "${changes##*$'\n'}" -eq 0 ]]; then
    error "Key not found: $key"
    return 1
  fi

  success "Removed mapping: $key"
}

is_url() {
  local value="$1"
  [[ "$value" =~ ^https?:// ]]
}

resolve_path() {
  local value="$1"
  if [[ "$value" == ~* ]]; then
    printf '%s\n' "${HOME}${value#\~}"
  else
    printf '%s\n' "$value"
  fi
}

open_mapping() {
  local key="$1"
  local value path

  validate_key "$key"
  ensure_db_ready

  if ! value="$(read_value "$key")"; then
    case "$?" in
      1)
        error "Key not found: $key"
        return 1
        ;;
      *)
        return 1
        ;;
    esac
  fi

  if is_url "$value"; then
    if command -v xdg-open >/dev/null 2>&1; then
      nohup xdg-open "$value" >/dev/null 2>&1 &
      success "Opened URL: $value"
      return 0
    fi
    error "xdg-open not found. Cannot open URL."
    return 1
  fi

  path="$(resolve_path "$value")"
  # Keep directory mappings shell-friendly by printing the path for caller-side `cd`.
  if [[ -d "$path" ]]; then
    printf '%s\n' "$path"
    return 0
  fi

  # Non-URL, non-directory values are treated as shell commands.
  bash -lc "$value"
}

print_path() {
  local key="$1"
  local value path

  validate_key "$key"
  ensure_db_ready

  if ! value="$(read_value "$key")"; then
    case "$?" in
      1)
        error "Key not found: $key"
        return 1
        ;;
      *)
        return 1
        ;;
    esac
  fi

  path="$(resolve_path "$value")"
  if [[ -d "$path" ]]; then
    printf '%s\n' "$path"
    return 0
  fi

  printf '%s\n' "$value"
}

fuzzy_open() {
  ensure_db_ready

  if ! command -v fzf >/dev/null 2>&1; then
    info "fzf is not installed. Install fzf to use fuzzy search."
    return 1
  fi

  local key
  # Query keys directly from SQLite to keep completion/fuzzy behavior backend-agnostic.
  key="$(sqlite3 -noheader "$DB_FILE" "SELECT key FROM mappings ORDER BY key;" | fzf --prompt='linkdir> ' --height=40% --reverse || true)"
  if [[ -z "$key" ]]; then
    return 0
  fi

  open_mapping "$key"
}

print_keys() {
  ensure_db_ready
  if ! sqlite3 -noheader "$DB_FILE" "SELECT key FROM mappings ORDER BY key;"; then
    error "Failed to read keys from database."
    return 1
  fi
}

main() {
  local cmd="${1:-help}"
  case "$cmd" in
    add)
      if [[ $# -lt 3 ]]; then
        error "Usage: linkdir add <key> <value>"
        exit 1
      fi
      add_mapping "$2" "${*:3}"
      ;;
    open)
      if [[ $# -lt 2 ]]; then
        error "Usage: linkdir open <key>"
        exit 1
      fi
      open_mapping "$2"
      ;;
    path)
      if [[ $# -lt 2 ]]; then
        error "Usage: linkdir path <key>"
        exit 1
      fi
      print_path "$2"
      ;;
    list)
      list_mappings
      ;;
    remove|rm|delete)
      if [[ $# -lt 2 ]]; then
        error "Usage: linkdir remove <key>"
        exit 1
      fi
      remove_mapping "$2"
      ;;
    f)
      fuzzy_open
      ;;
    _keys)
      print_keys
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      error "Unknown command: $cmd"
      usage
      exit 1
      ;;
  esac
}

main "$@"

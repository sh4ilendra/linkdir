#!/usr/bin/env bash
set -euo pipefail

PROGRAM="linkdir"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/linkdir"
DB_FILE="$CONFIG_DIR/links.db"

COLOR_ENABLED=0
if [[ -t 1 ]]; then
  COLOR_ENABLED=1
fi

color() {
  local code="$1"
  shift
  if [[ "$COLOR_ENABLED" -eq 1 ]]; then
    printf '\033[%sm%s\033[0m\n' "$code" "$*"
  else
    printf '%s\n' "$*"
  fi
}

info() {
  color "1" "$*"
}

success() {
  color "32" "$*"
}

error() {
  color "31" "$*" >&2
}

usage() {
  cat <<'EOF'
Usage:
  linkdir add <key> <value>      Add or overwrite a mapping
  linkdir open <key>             Open mapping: URL, directory, or shell command
  linkdir path <key>             Print directory/value for shell integration
  linkdir list                   List all mappings
  linkdir remove <key>           Remove a mapping
  linkdir f                      Fuzzy-find a key using fzf and open it
  linkdir help                   Show this help

Examples:
  linkdir add gh https://github.com
  linkdir add proj ~/workspace/project
  linkdir open gh
  linkdir open proj
  linkdir remove gh

Directory navigation note:
  A standalone executable cannot change your current shell directory.
  To jump directories from mappings, add this to your shell rc:

    lgo() { cd "$(linkdir path "$1")"; }

Then run:
  lgo proj
EOF
}

ensure_store() {
  mkdir -p "$CONFIG_DIR"
  touch "$DB_FILE"
}

validate_key() {
  local key="$1"
  if [[ -z "$key" ]]; then
    error "Key cannot be empty."
    return 1
  fi
  if [[ ! "$key" =~ ^[A-Za-z0-9._-]+$ ]]; then
    error "Invalid key '$key'. Use letters, numbers, dot, underscore, or hyphen."
    return 1
  fi
}

validate_db() {
  ensure_store
  local line_no=0
  local line key
  while IFS= read -r line || [[ -n "$line" ]]; do
    ((line_no += 1))
    [[ -z "$line" ]] && continue
    if [[ "$line" != *"|"* ]]; then
      error "Corrupted DB: missing delimiter on line $line_no."
      return 1
    fi
    key="${line%%|*}"
    if [[ -z "$key" ]]; then
      error "Corrupted DB: empty key on line $line_no."
      return 1
    fi
  done <"$DB_FILE"
}

read_value() {
  local key="$1"
  awk -F'|' -v k="$key" '$1==k{ sub(/^[^|]*\|/, "", $0); print $0; found=1; exit } END{ if(!found) exit 1 }' "$DB_FILE"
}

write_atomically() {
  local tmp
  tmp="$(mktemp "$CONFIG_DIR/.links.db.tmp.XXXXXX")"
  cat >"$tmp"
  mv "$tmp" "$DB_FILE"
}

add_mapping() {
  local key="${1:-}"
  local value="${2:-}"

  validate_key "$key"
  if [[ -z "$value" ]]; then
    error "Value cannot be empty."
    return 1
  fi

  ensure_store
  validate_db

  {
    awk -F'|' -v k="$key" '$1!=k { print $0 }' "$DB_FILE"
    printf '%s|%s\n' "$key" "$value"
  } | write_atomically
  success "Saved mapping: $key"
}

list_mappings() {
  ensure_store
  validate_db

  if [[ ! -s "$DB_FILE" ]]; then
    info "No mappings stored yet."
    return 0
  fi

  if command -v column >/dev/null 2>&1; then
    {
      printf 'KEY|VALUE\n'
      cat "$DB_FILE"
    } | column -t -s '|'
  else
    printf '%-20s %s\n' "KEY" "VALUE"
    awk -F'|' '{ if (NF>=2) { sub(/^[^|]*\|/, "", $0); printf "%-20s %s\n", $1, $0 } }' "$DB_FILE"
  fi
}

remove_mapping() {
  local key="${1:-}"
  validate_key "$key"
  ensure_store
  validate_db

  if ! awk -F'|' -v k="$key" '$1==k { found=1 } END{ exit(found?0:1) }' "$DB_FILE"; then
    error "Key not found: $key"
    return 1
  fi

  awk -F'|' -v k="$key" '$1!=k || $0 !~ /\|/ { print $0 }' "$DB_FILE" | write_atomically
  success "Removed mapping: $key"
}

is_url() {
  local value="$1"
  [[ "$value" =~ ^https?:// ]]
}

resolve_path() {
  local value="$1"
  if [[ "$value" == ~* ]]; then
    printf '%s\n' "${HOME}${value#\~}"
  else
    printf '%s\n' "$value"
  fi
}

open_mapping() {
  local key="$1"
  local value path

  validate_key "$key"
  ensure_store
  validate_db

  if ! value="$(read_value "$key")"; then
    error "Key not found: $key"
    return 1
  fi

  if is_url "$value"; then
    if command -v xdg-open >/dev/null 2>&1; then
      nohup xdg-open "$value" >/dev/null 2>&1 &
      success "Opened URL: $value"
      return 0
    fi
    error "xdg-open not found. Cannot open URL."
    return 1
  fi

  path="$(resolve_path "$value")"
  if [[ -d "$path" ]]; then
    printf '%s\n' "$path"
    return 0
  fi

  bash -lc "$value"
}

print_path() {
  local key="$1"
  local value path

  validate_key "$key"
  ensure_store
  validate_db

  if ! value="$(read_value "$key")"; then
    error "Key not found: $key"
    return 1
  fi

  path="$(resolve_path "$value")"
  if [[ -d "$path" ]]; then
    printf '%s\n' "$path"
    return 0
  fi

  printf '%s\n' "$value"
}

fuzzy_open() {
  ensure_store
  validate_db

  if ! command -v fzf >/dev/null 2>&1; then
    info "fzf is not installed. Install fzf to use fuzzy search."
    return 1
  fi

  local key
  key="$(awk -F'|' 'NF>=2{print $1}' "$DB_FILE" | fzf --prompt='linkdir> ' --height=40% --reverse || true)"
  if [[ -z "$key" ]]; then
    return 0
  fi

  open_mapping "$key"
}

print_keys() {
  ensure_store
  validate_db
  awk -F'|' 'NF>=2{print $1}' "$DB_FILE"
}

main() {
  local cmd="${1:-help}"
  case "$cmd" in
    add)
      if [[ $# -lt 3 ]]; then
        error "Usage: linkdir add <key> <value>"
        exit 1
      fi
      add_mapping "$2" "${*:3}"
      ;;
    open)
      if [[ $# -lt 2 ]]; then
        error "Usage: linkdir open <key>"
        exit 1
      fi
      open_mapping "$2"
      ;;
    path)
      if [[ $# -lt 2 ]]; then
        error "Usage: linkdir path <key>"
        exit 1
      fi
      print_path "$2"
      ;;
    list)
      list_mappings
      ;;
    remove|rm|delete)
      if [[ $# -lt 2 ]]; then
        error "Usage: linkdir remove <key>"
        exit 1
      fi
      remove_mapping "$2"
      ;;
    f)
      fuzzy_open
      ;;
    _keys)
      print_keys
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      error "Unknown command: $cmd"
      usage
      exit 1
      ;;
  esac
}

main "$@"
